      <bpmn:task id="ClearSelectedStageVariableNode" name="Clear selected stage variable value">
        <bpmn:extensionElements>
          <uipath:mapping version="v1">
            <uipath:type value="BPMN.Variables" version="v1" />
            <uipath:output name="UserSelectStageMessageResponse" type="jsonSchema" var="UserSelectStageMessageResponse" custom="true"><![CDATA[=js:(vars.EventSubProcessLatestEventType == "TaskCompleted" && (vars.EventSubProcessLatestEventParams != null && vars.EventSubProcessLatestEventParams.taskName != null && =js:["Wait for User to Select Next Stage for Evidence Gathering", "Wait for User to Select Next Stage for Strategy", "Wait for User to Select Next Stage for Response Drafting", "Wait for User to Select Next Stage for Human Review", "Wait for User to Select Next Stage for Submission", "Wait for User to Select Next Stage for Outcome Monitoring"].some((task) => task == vars.EventSubProcessLatestEventParams.taskName)) ? {} : vars.UserSelectStageMessageResponse)]]></uipath:output>
          </uipath:mapping>
        </bpmn:extensionElements>
        <bpmn:incoming>edge_Activity_Guardrails-ClearSelectedStageVariableNode</bpmn:incoming>
