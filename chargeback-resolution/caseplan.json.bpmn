      <bpmn:serviceTask id="Activity_Guardrails" name="Case manager guardrails">
        <bpmn:extensionElements>
          <uipath:activity version="v1">
            <uipath:type value="Maestro.CaseManagerGuardrails" version="v1" />
            <uipath:context>
              <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"decisions":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
            </uipath:context>
            <uipath:input name="body" type="json" target="body"><![CDATA[{"decisions":"=js:vars.caseManagerDecisions"}]]></uipath:input>
          </uipath:activity>
