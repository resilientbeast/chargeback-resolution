            </uipath:context>
            <uipath:input name="caseManagerInput" type="json" target="body"><![CDATA[{"caseRulesDecisions":"=js:(vars.caseRulesDecisions)","caseCurrentExecutionState":"=js:({ \"version\": 1, \"eventIdentifier\": vars.EventSubProcessEventIdentifier, \"event\": { \"type\": vars.EventSubProcessLatestEventType, \"parameters\": vars.EventSubProcessLatestEventParams, \"isExternal\": (vars.EventSubProcessLatestEventType == \"CaseEntered\" || vars.EventSubProcessLatestEventType == \"TaskCompleted\") ? false : true }, \"state\": { ...vars.caseState, \"vars\": { \"Fetch WooCommerce Order\": {  }, \"Fetch Stripe Evidence\": {  }, \"Score Evidence Quality\": {  }, \"Wait for User to Select Next Stage for Evidence Gathering\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Analyze Dispute Strategy\": {  }, \"Calculate Win Probability\": {  }, \"Wait for User to Select Next Stage for Strategy\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Draft Rebuttal Letter\": {  }, \"Package Evidence Bundle\": {  }, \"Wait for User to Select Next Stage for Response Drafting\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Review Response Package\": {  }, \"Wait for User to Select Next Stage for Human Review\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Submit to Stripe\": {  }, \"Confirm Submission\": {  }, \"Wait for User to Select Next Stage for Submission\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Monitor Dispute Status\": {  }, \"Close Case\": {  }, \"Wait for User to Select Next Stage for Outcome Monitoring\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Received event params\": { \"response\": (vars.mainEventSubprocessResponse.connectorResponse) } } } })"}]]></uipath:input>
