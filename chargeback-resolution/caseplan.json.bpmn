              <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"Reference":{"type":"string","title":"Reference"},"SpecificContent":{"type":"object","title":"Item information"},"TimeToLive":{"type":"duration","title":"Time to live"}},"required":["Reference","name"]}]]></uipath:inputSchema>
            </uipath:context>
            <uipath:input name="ItemData" type="json" target="body"><![CDATA[{"SpecificContent":{},"Reference":"=js:\"case-\" + metadata.InstanceId","Error":null,"TimeToLive":null}]]></uipath:input>
          </uipath:event>
        </bpmn:extensionElements>
        <bpmn:incoming>edge_eventSubprocessStagesExitedInclusiveGateway-stopStageSlaMessageEvent_Stage_Evid02</bpmn:incoming>
