        <bpmn:outgoing>edge_eventSubprocessStagesExitedInclusiveGateway-stopStageSlaMessageEvent_Stage_Strat3</bpmn:outgoing>
        <bpmn:outgoing>edge_eventSubprocessStagesExitedInclusiveGateway-stopStageSlaMessageEvent_Stage_Resp04</bpmn:outgoing>
        <bpmn:outgoing>edge_eventSubprocessStagesExitedInclusiveGateway-stopStageSlaMessageEvent_Stage_Humn05</bpmn:outgoing>
