      </bpmn:task>
      <bpmn:scriptTask id="GenerateUpdatedEventsNode" name="Generate updated events" scriptFormat="JavaScript">
        <bpmn:extensionElements>
          <uipath:mapping version="v1">
            <uipath:type value="BPMN.Variables" version="v1" />
            <uipath:context>
              <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"vars":{"type":"object"},"metadata":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
            </uipath:context>
            <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"vars":"=vars","metadata":"=metadata"}]]></uipath:input>
            <uipath:output name="scriptResponse" type="jsonSchema" source="=result.response" var="UpdatedEventsScriptResponse" />
            <uipath:output name="Error" type="jsonSchema" source="=result.response" var="UpdatedEventsScriptResponseError" />
          </uipath:mapping>
          <uipath:scriptVersion value="v3" />
        </bpmn:extensionElements>
        <bpmn:incoming>edge_ClearSelectedStageVariableNode-GenerateUpdatedEventsNode</bpmn:incoming>
        <bpmn:outgoing>edge_GenerateUpdatedEventsNode-EventSubProcessUpdateInstanceGlobalsNode</bpmn:outgoing>
        <bpmn:script><![CDATA[const stagesEnteredByKey = ((vars.caseManagerDecisions != null && vars.caseManagerDecisions.stagesEntered != null && vars.caseManagerDecisions.stagesEntered.length > 0)
 
? vars.caseManagerDecisions.stagesEntered.reduce((acc, stage) => {
acc[`CM:stagesEntered:${stage.stageName}`] = true;
return acc;
}, {}) 
: {});
const stagesExitedByKey = ((vars.caseManagerDecisions != null && vars.caseManagerDecisions.stagesExited != null && vars.caseManagerDecisions.stagesExited.length > 0)
 
? vars.caseManagerDecisions.stagesExited.reduce((acc, stage) => {
acc[`CM:stagesExited:${stage.stageName}`] = true;
return acc;
}, {}) 
: {});
const stagesCompletedByKey = ((vars.caseManagerDecisions != null && vars.caseManagerDecisions.stagesCompleted != null && vars.caseManagerDecisions.stagesCompleted.length > 0)
 
? vars.caseManagerDecisions.stagesCompleted.reduce((acc, stage) => {
acc[`CM:stagesCompleted:${stage.stageName}`] = true;
return acc;
}, {}) 
: {});
const allEventsUpdatedKeys = { ...stagesEnteredByKey, ...stagesExitedByKey, ...stagesCompletedByKey };
const lastPrimaryStageExited = [...(vars.caseManagerDecisions != null && vars.caseManagerDecisions.stagesCompleted != null && vars.caseManagerDecisions.stagesCompleted.length > 0 ? vars.caseManagerDecisions.stagesCompleted.map((stage) => stage.stageName) : []), ...(vars.caseManagerDecisions != null && vars.caseManagerDecisions.stagesExited != null && vars.caseManagerDecisions.stagesExited.length > 0 ? vars.caseManagerDecisions.stagesExited.map((stage) => stage.stageName) : [])];
const lastStageExited = [...(vars.caseManagerDecisions != null && vars.caseManagerDecisions.stagesCompleted != null && vars.caseManagerDecisions.stagesCompleted.length > 0 ? vars.caseManagerDecisions.stagesCompleted.map((stage) => stage.stageName) : []), ...(vars.caseManagerDecisions != null && vars.caseManagerDecisions.stagesExited != null && vars.caseManagerDecisions.stagesExited.length > 0 ? vars.caseManagerDecisions.stagesExited.map((stage) => stage.stageName) : [])];
if (lastPrimaryStageExited?.length) {
allEventsUpdatedKeys["CaseGlobalsLastPrimaryStageExited"] = lastPrimaryStageExited;
}
if (lastStageExited?.length) {
allEventsUpdatedKeys["CaseGlobalsLastStageExited"] = lastStageExited;
}

const exitedStageKeysToDelete = ((vars.caseManagerDecisions != null && vars.caseManagerDecisions.stagesEntered != null && vars.caseManagerDecisions.stagesEntered.length > 0)
 
? vars.caseManagerDecisions.stagesEntered.map((stage) => {
return `CM:stagesExited:${stage.stageName}`;
}, {}) 
: []);
const completedStageKeysToDelete = ((vars.caseManagerDecisions != null && vars.caseManagerDecisions.stagesEntered != null && vars.caseManagerDecisions.stagesEntered.length > 0)
 
? vars.caseManagerDecisions.stagesEntered.map((stage) => {
return `CM:stagesCompleted:${stage.stageName}`;
}, {}) 
: []);
const enteredStageKeysToDeleteForExits = ((vars.caseManagerDecisions != null && vars.caseManagerDecisions.stagesExited != null && vars.caseManagerDecisions.stagesExited.length > 0)
 
? vars.caseManagerDecisions.stagesExited.map((stage) => {
return `CM:stagesEntered:${stage.stageName}`;
}, {}) 
: []);
const enteredStageKeysToDeleteForCompletes = ((vars.caseManagerDecisions != null && vars.caseManagerDecisions.stagesCompleted != null && vars.caseManagerDecisions.stagesCompleted.length > 0)
 
? vars.caseManagerDecisions.stagesCompleted.map((stage) => {
return `CM:stagesEntered:${stage.stageName}`;
}, {}) 
: []);
return { upsertKeys: allEventsUpdatedKeys, deleteKeys: [...exitedStageKeysToDelete, ...completedStageKeysToDelete, ...enteredStageKeysToDeleteForExits, ...enteredStageKeysToDeleteForCompletes] };]]></bpmn:script>
      </bpmn:scriptTask>
      <bpmn:serviceTask id="EventSubProcessUpdateInstanceGlobalsNode" name="Update case state">
        <bpmn:extensionElements>
          <uipath:activity version="v1">
