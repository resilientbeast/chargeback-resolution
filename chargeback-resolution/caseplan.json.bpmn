            <uipath:input name="caseManagerInput" type="json" target="body"><![CDATA[{"caseDeterministicRules":{"case":{"completionConditions":[{"completionConditionType":"StagesCompleted","parameters":{"stageNames":["Evidence Gathering","Strategy","Response Drafting","Human Review","Submission","Outcome Monitoring"]},"ruleName":"Complete Rule 1"}]},"stages":[{"name":"Evidence Gathering","entryConditions":[{"entryConditionType":"CaseEntered","parameters":{},"ruleName":"Entry Rule 1"}],"exitConditions":[],"completionConditions":[{"completionConditionType":"TasksCompleted","parameters":{"taskNames":["Fetch WooCommerce Order","Fetch Stripe Evidence","Score Evidence Quality"]},"ruleName":"Complete Rule 1"}],"tasks":[{"name":"Fetch WooCommerce Order","runOnlyOnce":true,"entryConditions":[{"entryConditionType":"StageEntered","parameters":{"stageNames":["Evidence Gathering"]},"ruleName":"Start"}]},{"name":"Fetch Stripe Evidence","runOnlyOnce":true,"entryConditions":[{"entryConditionType":"StageEntered","parameters":{"stageNames":["Evidence Gathering"]},"ruleName":"Start"}]},{"name":"Score Evidence Quality","runOnlyOnce":true,"entryConditions":[{"entryConditionType":"TasksCompleted","parameters":{"taskNames":["Fetch WooCommerce Order","Fetch Stripe Evidence"]},"ruleName":"After Evidence Fetch"}]}]},{"name":"Strategy","entryConditions":[{"entryConditionType":"StagesCompleted","parameters":{"stageNames":["Evidence Gathering"]},"ruleName":"Entry Rule 1"}],"exitConditions":[],"completionConditions":[{"completionConditionType":"TasksCompleted","parameters":{"taskNames":["Analyze Dispute Strategy","Calculate Win Probability"]},"ruleName":"Complete Rule 1"}],"tasks":[{"name":"Analyze Dispute Strategy","runOnlyOnce":true,"entryConditions":[{"entryConditionType":"StageEntered","parameters":{"stageNames":["Strategy"]},"ruleName":"Start"}]},{"name":"Calculate Win Probability","runOnlyOnce":true,"entryConditions":[{"entryConditionType":"TasksCompleted","parameters":{"taskNames":["Analyze Dispute Strategy"]},"ruleName":"After Strategy Analysis"}]}]},{"name":"Response Drafting","entryConditions":[{"entryConditionType":"StagesCompleted","parameters":{"stageNames":["Strategy"]},"ruleName":"Entry Rule 1"}],"exitConditions":[],"completionConditions":[{"completionConditionType":"TasksCompleted","parameters":{"taskNames":["Draft Rebuttal Letter","Package Evidence Bundle"]},"ruleName":"Complete Rule 1"}],"tasks":[{"name":"Draft Rebuttal Letter","runOnlyOnce":true,"entryConditions":[{"entryConditionType":"StageEntered","parameters":{"stageNames":["Response Drafting"]},"ruleName":"Start"}]},{"name":"Package Evidence Bundle","runOnlyOnce":true,"entryConditions":[{"entryConditionType":"TasksCompleted","parameters":{"taskNames":["Draft Rebuttal Letter"]},"ruleName":"After Draft Rebuttal"}]}]},{"name":"Human Review","entryConditions":[{"entryConditionType":"StagesCompleted","parameters":{"stageNames":["Response Drafting"]},"ruleName":"Entry Rule 1"}],"exitConditions":[],"completionConditions":[{"completionConditionType":"TasksCompleted","parameters":{"taskNames":["Review Response Package"]},"ruleName":"Complete Rule 1"}],"tasks":[]},{"name":"Submission","entryConditions":[{"entryConditionType":"StagesCompleted","parameters":{"stageNames":["Human Review"]},"ruleName":"Entry Rule 1"}],"exitConditions":[],"completionConditions":[{"completionConditionType":"TasksCompleted","parameters":{"taskNames":["Submit to Stripe","Confirm Submission"]},"ruleName":"Complete Rule 1"}],"tasks":[{"name":"Confirm Submission","runOnlyOnce":true,"entryConditions":[{"entryConditionType":"TasksCompleted","parameters":{"taskNames":["Submit to Stripe"]},"ruleName":"After Submit"}]}]},{"name":"Outcome Monitoring","entryConditions":[{"entryConditionType":"StagesCompleted","parameters":{"stageNames":["Submission"]},"ruleName":"Entry Rule 1"}],"exitConditions":[],"completionConditions":[{"completionConditionType":"TasksCompleted","parameters":{"taskNames":["Monitor Dispute Status","Close Case"]},"ruleName":"Complete Rule 1"}],"tasks":[{"name":"Close Case","runOnlyOnce":true,"entryConditions":[{"entryConditionType":"TasksCompleted","parameters":{"taskNames":["Monitor Dispute Status"]},"ruleName":"After Monitor"}]}]}],"version":1},"caseCurrentExecutionState":"=js:({ \"version\": 1, \"eventIdentifier\": vars.EventSubProcessEventIdentifier, \"event\": { \"type\": vars.EventSubProcessLatestEventType, \"parameters\": vars.EventSubProcessLatestEventParams, \"isExternal\": (vars.EventSubProcessLatestEventType == \"CaseEntered\" || vars.EventSubProcessLatestEventType == \"TaskCompleted\") ? false : true }, \"state\": { ...vars.caseState, \"vars\": { \"Fetch WooCommerce Order\": {  }, \"Fetch Stripe Evidence\": {  }, \"Score Evidence Quality\": {  }, \"Wait for User to Select Next Stage for Evidence Gathering\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Analyze Dispute Strategy\": {  }, \"Calculate Win Probability\": {  }, \"Wait for User to Select Next Stage for Strategy\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Draft Rebuttal Letter\": {  }, \"Package Evidence Bundle\": {  }, \"Wait for User to Select Next Stage for Response Drafting\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Review Response Package\": {  }, \"Wait for User to Select Next Stage for Human Review\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Submit to Stripe\": {  }, \"Confirm Submission\": {  }, \"Wait for User to Select Next Stage for Submission\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Monitor Dispute Status\": {  }, \"Close Case\": {  }, \"Wait for User to Select Next Stage for Outcome Monitoring\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Received event params\": { \"response\": (vars.mainEventSubprocessResponse.connectorResponse) } } } })"}]]></uipath:input>
            <uipath:output name="caseRulesDecisions" type="json" source="=result" var="caseRulesDecisions" custom="true" />
          </uipath:activity>
        </bpmn:extensionElements>
